# Copy to .env and fill in. Never commit .env — see .gitignore.

# --- Database (Railway Postgres plugin) ---
DATABASE_URL=postgresql://user:password@localhost:5432/ovyro   # Postgres connection string
DATABASE_POOL_MAX=10                                           # Max pg pool connections per process (web and worker each open their own)

# --- Redis (Railway Redis plugin) — BullMQ queues + rate limiting ---
REDIS_URL=redis://localhost:6379                               # Redis connection string

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET=replace-with-32-byte-random-string          # Signs sessions; generate with `openssl rand -base64 32`
BETTER_AUTH_URL=http://localhost:3000                          # Base URL Better Auth issues callbacks against
NEXT_PUBLIC_APP_URL=http://localhost:3000                      # Public origin used in emails, OG tags, and canonical URLs

# --- Transactional email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx                         # Lead notification + OTP delivery
EMAIL_FROM=Ovyro <noreply@ovyro.com>                           # Verified sender for all transactional mail; must be a domain verified in Resend

# --- Secret encryption ---
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-random-string        # Encrypts Meta tokens at rest; rotating it invalidates stored tokens

# --- Monitoring (Sentry) — unset means Sentry is a no-op ---
SENTRY_DSN=                                                    # Server-side DSN
NEXT_PUBLIC_SENTRY_DSN=                                        # Browser DSN (must be NEXT_PUBLIC_ to reach the client bundle)

# --- Object storage (Cloudflare R2) ---
R2_ACCOUNT_ID=                                                 # Cloudflare account ID
R2_ACCESS_KEY_ID=                                              # R2 access key
R2_SECRET_ACCESS_KEY=                                          # R2 secret key
R2_BUCKET=ovyro-media                                          # Bucket holding listing photos and image variants
R2_PUBLIC_BASE_URL=                                            # Public base URL media is served from (bucket r2.dev URL or custom CDN domain), no trailing slash

# --- Video (Mux) ---
MUX_TOKEN_ID=                                                  # Mux API token ID
MUX_TOKEN_SECRET=                                              # Mux API token secret

# --- Meta (Facebook) Pixel + Conversions API ---
META_APP_ID=                                                   # Meta app ID used for seller OAuth
META_APP_SECRET=                                               # Meta app secret — server-side only, never expose

# --- Phone OTP (Twilio Verify) ---
TWILIO_ACCOUNT_SID=                                            # Twilio account SID
TWILIO_AUTH_TOKEN=                                             # Twilio auth token
TWILIO_VERIFY_SERVICE_SID=                                     # Twilio Verify service SID used for phone OTP
