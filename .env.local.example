# Local development environment for running Ovyro at http://localhost:3000
# WITHOUT any cloud credentials (no R2, Twilio, Meta, or Resend).
#
# Copy this to `.env.local` — Next.js and Bun both load `.env.local`
# automatically, and it is git-ignored so your machine values never get committed:
#
#   cp .env.local.example .env.local
#
# Then run the one-command bring-up: `bash scripts/dev-setup.sh`.
# The demo seed (scripts/seed-demo.ts) fills the marketplace from local Postgres,
# so browse, filters, search, and listing pages all render without cloud media.

# --- Database (local Homebrew postgresql@16) ---
# Homebrew Postgres creates a superuser role named after your macOS user, with no
# password. Replace `hrushi` with the output of `whoami` if it differs.
DATABASE_URL=postgresql://hrushi@localhost:5432/ovyro
DATABASE_POOL_MAX=10

# --- Redis (local Homebrew redis) — BullMQ queues + rate limiting ---
REDIS_URL=redis://localhost:6379

# --- Auth (Better Auth) ---
# Any 32-byte value works locally. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-any-32-byte-random-string
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Transactional email (Resend) — leave blank locally ---
# With no RESEND_API_KEY, email sends (lead notifications, OTP) become no-ops
# instead of throwing, so local auth and seeding still work.
RESEND_API_KEY=
EMAIL_FROM=Ovyro <noreply@ovyro.local>

# --- Secret encryption (Meta tokens at rest) — any 32-byte value locally ---
TOKEN_ENCRYPTION_KEY=replace-with-any-32-byte-random-string

# --- Everything below is intentionally blank locally --------------------------
# None of it is needed to browse the demo marketplace. Fill in only the service
# you are actively working on.

# Object storage (Cloudflare R2) — demo media uses picsum.photos placeholders.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Video (Mux)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Meta (Facebook) Pixel + Conversions API
META_APP_ID=
META_APP_SECRET=

# Phone OTP (Twilio Verify)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Monitoring (Sentry) — unset means Sentry is a no-op
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
